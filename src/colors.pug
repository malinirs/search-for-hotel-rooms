- let colorsValues = [{ name: 'Dark Shade 100%', number: '#1F2041' }, { name: 'Dark Shade 75%', number: '#1F2041' }, { name: 'Dark Shade 50%', number: '#1F2041' }, { name: 'Dark Shade 25%', number: '#1F2041' }, { name: 'Dark Shade 5%', number: '#1F2041' }, { name: 'Purple', number: '#BC9CFF' }, { name: 'Green', number: '#6FCF97' }];

.colors
  each i in colorsValues
    .description-colors
      .color-square
      .color-text
        .color-name #{i.name}
        .color-numer #{i.number}
